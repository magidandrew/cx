{
  "name": "claude-code-extensions",
  "version": "0.2.18",
  "description": "Modular, opt-in patches for @anthropic-ai/claude-code applied at runtime via AST transformation",
  "type": "module",
  "bin": {
    "cx": "./dist/cli.js",
    "cx-setup": "./dist/cli-setup.js",
    "cx-list": "./dist/cli-list.js",
    "cx-reload": "./dist/cli-reload.js"
  },
  "files": [
    "dist/",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "link": "tsc && npm link",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build",
    "test": "bun test test/patches --timeout=60000 --max-concurrency=1",
    "test:patches": "bun scripts/test-patches.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.5.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-code": {
      "optional": true
    }
  },
  "keywords": [
    "claude",
    "claude-code",
    "extensions",
    "patches"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/magidandrew/cx"
  },
  "homepage": "https://cx.worms.coffee",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
